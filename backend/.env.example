# Backend environment variables
# Copy this file to .env and fill in the values

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost/tumtum

# Redis
REDIS_URL=redis://localhost:6379

# Auth
SECRET_KEY=change-me-to-a-random-secret-key

# Google OAuth (for Google Fit / Health Connect)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# External APIs
SETLIST_FM_API_KEY=
API_FOOTBALL_KEY=

# Monitoring
SENTRY_DSN=
ENVIRONMENT=development
